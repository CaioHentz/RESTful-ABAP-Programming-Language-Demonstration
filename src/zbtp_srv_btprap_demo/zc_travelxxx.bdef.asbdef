projection;

define behavior for zc_travelxxx alias Travel
use etag
{
  use create;
  use update;
  use delete;

  use action acceptTravel;
  use action rejectTravel;

  use association _Booking { create; }

}

define behavior for zc_bookingxxx alias Booking
use etag
{
 use update;
 use delete;

 use association _Travel;
}